//@version=5
strategy("Multi-Indicator Combo Strategy (v5 Compatible)", overlay=true, margin_long=100, margin_short=100, default_qty_type=strategy.percent_of_equity, default_qty_value=100)

//--------------------------------------------------------------------
// 1) GÖSTERGE HESAPLAMALARI
//--------------------------------------------------------------------

// --- Ichimoku Bulutu (9-26-52) ---
length_conv  = input.int(9,  "Tenkan (Conversion) Periyot", minval=1)
length_base  = input.int(26, "Kijun (Base) Periyot",       minval=1)
length_spanB = input.int(52, "Span B Periyot",             minval=1)

// Ichimoku çizgileri
float conversionLine = (ta.highest(high, length_conv) + ta.lowest(low, length_conv)) / 2
float baseLine       = (ta.highest(high, length_base) + ta.lowest(low, length_base)) / 2
float spanA          = (conversionLine + baseLine) / 2
float spanB          = (ta.highest(high, length_spanB) + ta.lowest(low, length_spanB)) / 2
float lagLine        = close[length_base]

//--------------------------------------------------------------------
// --- Parabolic SAR (v5) ---
psar_start = input.float(0.02, "PSAR Start", step=0.001, minval=0.001)
psar_inc   = input.float(0.02, "PSAR Increment", step=0.001, minval=0.001)
psar_max   = input.float(0.2,  "PSAR Max", step=0.01,  minval=0.01)
float psar = ta.sar(psar_start, psar_inc, psar_max)

//--------------------------------------------------------------------
// --- SuperTrend (ta.supertrend) (v5)
//     ta.supertrend(factor, atrPeriod) → [series float, series float]
//     Not: Bazı Pine sürümlerinde ikinci değer 1.0 / -1.0 döndürebilir.
//
//  1. Değer: SuperTrend çizgisi (float)
//  2. Değer: Trend yönünü ifade eden float (genelde 1.0 = up, -1.0 = down)
//--------------------------------------------------------------------
st_atrPeriod = input.int(10,   "SuperTrend ATR Periyodu", minval=1)
st_factor    = input.float(3.0,"SuperTrend Faktörü", step=0.1, minval=0.1)

// Önce değişkenleri tanımlıyoruz (var) sonra dizi ataması yapıyoruz
var float stLine     = na
var float stTrendVal = na

[_stLineTemp, _stTrendValTemp] = ta.supertrend(st_factor, st_atrPeriod)
stLine     := _stLineTemp
stTrendVal := _stTrendValTemp

// Eğer ta.supertrend() 1.0 veya -1.0 döndürüyorsa, boğa/ayı şeklinde bool’a çevirebiliriz:
bool superTrendBull = stTrendVal == 1.0
bool superTrendBear = stTrendVal == -1.0

//--------------------------------------------------------------------
// --- Bollinger Bantları ---
bb_length = input.int(20, "Bollinger Bant Periyodu", minval=1)
bb_std    = input.float(2.0, "Bollinger Std Dev", step=0.1, minval=0.1)
[bb_mid, bb_upper, bb_lower] = ta.bb(close, bb_length, bb_std)

//--------------------------------------------------------------------
// --- Üssel Hareketli Ortalamalar (EMA) ---
float ema5   = ta.ema(close, 5)
float ema10  = ta.ema(close, 10)
float ema20  = ta.ema(close, 20)
float ema50  = ta.ema(close, 50)
float ema100 = ta.ema(close, 100)
float ema200 = ta.ema(close, 200)
float ema377 = ta.ema(close, 377)
float ema610 = ta.ema(close, 610)

//--------------------------------------------------------------------
// --- RSI ---
rsi_length = input.int(14, "RSI Periyodu", minval=1)
float rsi  = ta.rsi(close, rsi_length)

//--------------------------------------------------------------------
// --- MACD --- (standart 12, 26, 9)
macd_fast   = input.int(12, "MACD Hızlı EMA",  minval=1)
macd_slow   = input.int(26, "MACD Yavaş EMA",  minval=1)
macd_signal = input.int(9,  "MACD Sinyal EMA", minval=1)
[macdLine, macdSignal, macdHist] = ta.macd(close, macd_fast, macd_slow, macd_signal)

//--------------------------------------------------------------------
// --- Fisher Transform (Ehlers) ---
fisher_length = input.int(9, "Fisher Transform Length", minval=1)

// Değişkenler (var):
var float fishValue = na
var float fish      = na

if barstate.isfirst
    fishValue := 0.0
    fish := 0.0

float medPrice = (high + low)/2
float minLow   = ta.lowest(low, fisher_length)
float maxHigh  = ta.highest(high, fisher_length)

float value = 0.0
if maxHigh != minLow
    value := 2 * ((medPrice - minLow)/(maxHigh - minLow) - 0.5)

// Fisher’a ek filtre uygulama (önceki değerden yumuşatma)
value := 0.33 * value + 0.67 * nz(fishValue[1], 0)

// clamp yerine if-else
if value > 0.999
    value := 0.999
else if value < -0.999
    value := -0.999

fishValue := value
fish := 0.5 * math.log((1 + value)/(1 - value)) + 0.5 * nz(fish[1], 0)

//--------------------------------------------------------------------
// 2) TREND ve MOMENTUM KOŞULLARI -> AL / SAT sinyali üretimi
//--------------------------------------------------------------------

// Ichimoku tarafında da math.max(), math.min() yerine klasik max(), min() fonksiyonlarını kullanalım
bool ichimokuBull = close > math.max(spanA, spanB)
bool ichimokuBear = close < math.min(spanA, spanB)

// PSAR boğa/ayı
bool psarBull = close > psar
bool psarBear = close < psar

// SuperTrend boğa/ayı (dönüştürme)
bool stBull = superTrendBull  // stTrendVal == 1.0
bool stBear = superTrendBear  // stTrendVal == -1.0

// EMA (fiyatın 50 ve 200 üzerinde/altında olması)
bool emaBull = close > ema50 and close > ema200
bool emaBear = close < ema50 and close < ema200

// --- Momentum Koşulları ---
bool rsiBull    = rsi > 50
bool rsiBear    = rsi < 50
bool macdBull   = macdLine > macdSignal
bool macdBear   = macdLine < macdSignal
bool fisherBull = fish > 0
bool fisherBear = fish < 0

// Kaç tane Bull / Bear trend koşulu sağlanıyor?
int bullTrendCount = 0
bullTrendCount += ichimokuBull ? 1 : 0
bullTrendCount += psarBull     ? 1 : 0
bullTrendCount += stBull       ? 1 : 0
bullTrendCount += emaBull      ? 1 : 0

int bearTrendCount = 0
bearTrendCount += ichimokuBear ? 1 : 0
bearTrendCount += psarBear     ? 1 : 0
bearTrendCount += stBear       ? 1 : 0
bearTrendCount += emaBear      ? 1 : 0

// Kaç tane Bull / Bear momentum koşulu sağlanıyor?
int bullMomentumCount = 0
bullMomentumCount += rsiBull    ? 1 : 0
bullMomentumCount += macdBull   ? 1 : 0
bullMomentumCount += fisherBull ? 1 : 0

int bearMomentumCount = 0
bearMomentumCount += rsiBear    ? 1 : 0
bearMomentumCount += macdBear   ? 1 : 0
bearMomentumCount += fisherBear ? 1 : 0

// Nihai AL / SAT Sinyalleri
bool buySignal  = (bullTrendCount >= 3) and (bullMomentumCount >= 2)
bool sellSignal = (bearTrendCount >= 3) and (bearMomentumCount >= 2)

//--------------------------------------------------------------------
// 3) STRATEJİ İŞLEM YÖNETİMİ
//--------------------------------------------------------------------
allowShort = input.bool(true, "Kısa İşlem Aç (Short)?")

if buySignal
    // Elimizde short pozisyon varsa kapat
    if strategy.position_size < 0
        strategy.close("Short")
    // Flat veya long konumdaysak; yeni al
    if strategy.position_size <= 0
        strategy.entry("Long", strategy.long)

if sellSignal
    // Elimizde long varsa kapat
    if strategy.position_size > 0
        strategy.close("Long")
    // Kısa işlemlere izin verildiyse short aç
    if allowShort and strategy.position_size >= 0
        strategy.entry("Short", strategy.short)

//--------------------------------------------------------------------
// 4) GRAFİK GÖRSELLERİ
//--------------------------------------------------------------------

// Ichimoku çizgileri
plot(conversionLine, title="Ichimoku Tenkan", color=color.blue)
plot(baseLine,       title="Ichimoku Kijun",  color=color.red)
plot(lagLine,        title="Ichimoku Chikou", color=color.gray)
pSpanA = plot(spanA, title="Ichimoku Span A", color=color.green,  offset=length_base)
pSpanB = plot(spanB, title="Ichimoku Span B", color=color.maroon, offset=length_base)
fill(pSpanA, pSpanB, title="Ichimoku Cloud", color=spanA > spanB ? color.new(color.green, 80) : color.new(color.red, 80))

// PSAR (trend yönüne göre renk)
plot(psar, title="Parabolic SAR", style=plot.style_cross, color= close > psar ? color.lime : color.red)

// SuperTrend (trendVal = 1.0 => yeşil, -1.0 => fuşya)
plot(stLine, title="SuperTrend", linewidth=2, color=stBull ? color.lime : color.fuchsia)

// Bollinger Bantları
plot(bb_mid,   title="BB Mid", color=color.new(color.purple, 30))
plot(bb_upper, title="BB Üst", color=color.purple)
plot(bb_lower, title="BB Alt", color=color.purple)

// EMA’lar
plot(ema5,   title="EMA 5",   color=color.lime)
plot(ema10,  title="EMA 10",  color=color.yellow)
plot(ema20,  title="EMA 20",  color=color.fuchsia)
plot(ema50,  title="EMA 50",  color=color.blue)
plot(ema100, title="EMA 100", color=color.orange)
plot(ema200, title="EMA 200", color=color.red, linewidth=2)
plot(ema377, title="EMA 377", color=color.aqua)
plot(ema610, title="EMA 610", color=color.navy)

// RSI, MACD, Fisher değerleri (fiyat grafiğini bozabilir, panel ayarlarını yapın)
plot(rsi,        title="RSI",            color=color.white)
plot(macdLine,   title="MACD Çizgi",     color=color.aqua)
plot(macdSignal, title="MACD Sinyal",    color=color.purple)
plot(fish,       title="FisherTransform",color=color.yellow)

// Al / Sat işaretleri
plotshape(buySignal,  style=shape.triangleup,   title="Buy Signal",  text="AL",  location=location.belowbar, color=color.green, size=size.tiny)
plotshape(sellSignal, style=shape.triangledown, title="Sell Signal", text="SAT", location=location.abovebar, color=color.red,   size=size.tiny)
