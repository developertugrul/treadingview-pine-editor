// @version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║         KURLAR TREND PAKETİ — v6                            ║
// ║  EMA · SuperTrend · Daily Pivot · S/R · MTF                 ║
// ║  EURUSD · USDTRY · GBPUSD · USDJPY ve tüm döviz çiftleri   ║
// ║  Birlikte Çalışır: seans-suite · momentum-suite             ║
// ╚══════════════════════════════════════════════════════════════╝
indicator("Kurlar Trend Paketi", overlay=true, max_bars_back=500, max_labels_count=50)

// ══════════════════════════════════════════════════════════════
// DARK MODE
// ══════════════════════════════════════════════════════════════
_bg_lum  = color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)
is_dark  = _bg_lum < 383

C_BULL   = is_dark ? color.new(#00C851, 0) : color.new(#006621, 0)
C_BEAR   = is_dark ? color.new(#FF4444, 0) : color.new(#CC0000, 0)
C_NEUT   = is_dark ? color.new(#9B9B9B, 0) : color.new(#444444, 0)
C_ACCENT = is_dark ? color.new(#2196F3, 0) : color.new(#1565C0, 0)
C_WARN   = is_dark ? color.new(#FFC107, 0) : color.new(#E65100, 0)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grp_ema = "── Hareketli Ortalamalar ──"
ema8_on   = input.bool(true,  "EMA 8",   group=grp_ema)
ema21_on  = input.bool(true,  "EMA 21",  group=grp_ema)
ema50_on  = input.bool(true,  "EMA 50",  group=grp_ema)
ema200_on = input.bool(true,  "EMA 200", group=grp_ema)
bar_renk  = input.bool(true,  "Bar Renk",group=grp_ema)

grp_st = "── SuperTrend ──"
st_on   = input.bool(true,   "SuperTrend", group=grp_st)
st_per  = input.int(14,      "Periyot (Forex: 14 önerilir)", minval=3, group=grp_st)
st_mult = input.float(3.0,   "Çarpan", minval=0.5, maxval=10, step=0.1, group=grp_st)

grp_pivot = "── Daily Pivot ──"
pivot_on = input.bool(true, "Daily Pivot Seviyeleri (R1/S1)", group=grp_pivot)

grp_sr = "── Destek / Direnç ──"
sr_on  = input.bool(true, "S/R Seviyeleri", group=grp_sr)
sr_lb  = input.int(14,    "Pivot Lookback", minval=5, maxval=50, group=grp_sr)

grp_mtf = "── MTF ──"
mtf_tf = input.timeframe("D", "Konfirmasyon TF", group=grp_mtf)

// ══════════════════════════════════════════════════════════════
// EMA
// ══════════════════════════════════════════════════════════════
ema8   = ta.ema(close, 8)
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema200 = ta.ema(close, 200)
golden_cross = ta.crossover(ema50,  ema200)
death_cross  = ta.crossunder(ema50, ema200)

// ══════════════════════════════════════════════════════════════
// SUPERTREND
// ══════════════════════════════════════════════════════════════
[st_val, st_dir] = ta.supertrend(st_mult, st_per)
st_yukari = st_dir < 0
st_alim   = ta.crossunder(st_dir, 0)
st_satim  = ta.crossover(st_dir,  0)

// ══════════════════════════════════════════════════════════════
// DAILY PIVOT SEVİYELERİ
// ══════════════════════════════════════════════════════════════
prev_h = request.security(syminfo.tickerid, "D", high[1],  lookahead=barmerge.lookahead_off)
prev_l = request.security(syminfo.tickerid, "D", low[1],   lookahead=barmerge.lookahead_off)
prev_c = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_off)

pp = (prev_h + prev_l + prev_c) / 3
r1 = 2 * pp - prev_l
r2 = pp + (prev_h - prev_l)
r3 = prev_h + 2 * (pp - prev_l)
s1 = 2 * pp - prev_h
s2 = pp - (prev_h - prev_l)
s3 = prev_l - 2 * (prev_h - pp)

// ══════════════════════════════════════════════════════════════
// MTF
// ══════════════════════════════════════════════════════════════
[mtf_e50, mtf_e200] = request.security(syminfo.tickerid, mtf_tf,
    [ta.ema(close,50), ta.ema(close,200)], lookahead=barmerge.lookahead_off)
mtf_yukari = mtf_e50 > mtf_e200
genel_yukari = st_yukari and mtf_yukari
genel_asagi  = not st_yukari and not mtf_yukari

// ══════════════════════════════════════════════════════════════
// S/R
// ══════════════════════════════════════════════════════════════
ph = ta.pivothigh(high, sr_lb, sr_lb)
pl = ta.pivotlow(low,   sr_lb, sr_lb)
var float res1 = na, var float res2 = na
var float sup1 = na, var float sup2 = na
if not na(ph) : res2 := res1; res1 := ph
if not na(pl) : sup2 := sup1; sup1 := pl

// ══════════════════════════════════════════════════════════════
// PLOT — EMA
// ══════════════════════════════════════════════════════════════
c_e8   = is_dark ? color.new(#FFD700, 0) : color.new(#F57F17, 0)
c_e21  = is_dark ? color.new(#42A5F5, 0) : color.new(#1565C0, 0)
c_e50  = is_dark ? color.new(#FFA726, 0) : color.new(#E65100, 0)
c_e200 = is_dark ? color.new(#CE93D8, 0) : color.new(#6A1B9A, 0)

p_e8  = plot(ema8_on   ? ema8   : na, "EMA 8",   color=c_e8,   linewidth=1)
p_e21 = plot(ema21_on  ? ema21  : na, "EMA 21",  color=c_e21,  linewidth=1)
        plot(ema50_on  ? ema50  : na, "EMA 50",  color=c_e50,  linewidth=2)
        plot(ema200_on ? ema200 : na, "EMA 200", color=c_e200, linewidth=3)
fill(p_e8, p_e21, color=ema8 > ema21 ? color.new(C_BULL,90) : color.new(C_BEAR,90))

plot(st_on ? st_val : na, "SuperTrend", color=st_yukari ? C_BULL : C_BEAR, linewidth=2)
plotshape(st_on and st_alim,  "ST Al",  shape.triangleup,   location.belowbar, C_BULL, size=size.small)
plotshape(st_on and st_satim, "ST Sat", shape.triangledown, location.abovebar, C_BEAR, size=size.small)
plotshape(golden_cross, "Golden Cross", shape.star,   location.belowbar, C_WARN, size=size.normal)
plotshape(death_cross,  "Death Cross",  shape.xcross, location.abovebar, C_BEAR, size=size.normal)

// ══════════════════════════════════════════════════════════════
// PLOT — Daily Pivots
// ══════════════════════════════════════════════════════════════
plot(pivot_on ? pp : na, "PP",   color=color.new(C_NEUT, 30), linewidth=1)
plot(pivot_on ? r1 : na, "R1",   color=color.new(C_BEAR, 30), linewidth=1, style=plot.style_circles)
plot(pivot_on ? r2 : na, "R2",   color=color.new(C_BEAR, 55), linewidth=1, style=plot.style_circles)
plot(pivot_on ? s1 : na, "S1",   color=color.new(C_BULL, 30), linewidth=1, style=plot.style_circles)
plot(pivot_on ? s2 : na, "S2",   color=color.new(C_BULL, 55), linewidth=1, style=plot.style_circles)

// ══════════════════════════════════════════════════════════════
// PLOT — S/R
// ══════════════════════════════════════════════════════════════
plot(sr_on ? res1 : na, "Direnç 1", color=color.new(C_BEAR, 25), linewidth=2)
plot(sr_on ? res2 : na, "Direnç 2", color=color.new(C_BEAR, 60), linewidth=1)
plot(sr_on ? sup1 : na, "Destek 1", color=color.new(C_BULL, 25), linewidth=2)
plot(sr_on ? sup2 : na, "Destek 2", color=color.new(C_BULL, 60), linewidth=1)

barcolor(bar_renk ? (genel_yukari ? color.new(C_BULL,65) : genel_asagi ? color.new(C_BEAR,65) : color.new(C_NEUT,80)) : na)

if barstate.islast
    trend_txt = genel_yukari ? "▲ YUKARI" : genel_asagi ? "▼ AŞAĞI" : "~ Kararsız"
    trend_col = genel_yukari ? C_BULL     : genel_asagi ? C_BEAR    : C_NEUT
    label.new(bar_index+2, high,
              trend_txt + " | MTF " + mtf_tf + ": " + (mtf_yukari ? "↑" : "↓") + "\n" +
              "PP: " + str.tostring(pp,"#.#####"),
              color=color.new(trend_col,80), textcolor=trend_col,
              style=label.style_label_left, size=size.small)

alertcondition(golden_cross, "Golden Cross",  "🟡 GOLDEN CROSS | {{ticker}} @ {{close}}")
alertcondition(death_cross,  "Death Cross",   "🔴 DEATH CROSS  | {{ticker}} @ {{close}}")
alertcondition(st_alim,      "ST Alım",       "🟢 ST ALIM | {{ticker}} @ {{close}}")
alertcondition(st_satim,     "ST Satım",      "🔴 ST SATIM | {{ticker}} @ {{close}}")

if barstate.isconfirmed
    if st_alim  : alert('{"event":"KUR_ST_ALIM","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar_close)
    if st_satim : alert('{"event":"KUR_ST_SATIM","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) + '}', alert.freq_once_per_bar_close)
