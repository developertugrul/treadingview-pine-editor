// @version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║        HİSSE VOLATİLİTE PAKETİ — v6                         ║
// ║  Bollinger Bands · Keltner Channel · BB Squeeze · ATR        ║
// ║  Birlikte Çalışır: trend-suite · sinyal-suite                ║
// ╚══════════════════════════════════════════════════════════════╝
indicator("Hisse Volatilite Paketi", overlay=true, max_bars_back=500)

// ══════════════════════════════════════════════════════════════
// DARK MODE DETECTION
// ══════════════════════════════════════════════════════════════
_bg_lum  = color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)
is_dark  = _bg_lum < 383

C_BULL   = is_dark ? color.new(#00C851, 0) : color.new(#006621, 0)
C_BEAR   = is_dark ? color.new(#FF4444, 0) : color.new(#CC0000, 0)
C_NEUT   = is_dark ? color.new(#9B9B9B, 0) : color.new(#444444, 0)
C_ACCENT = is_dark ? color.new(#2196F3, 0) : color.new(#1565C0, 0)
C_WARN   = is_dark ? color.new(#FFC107, 0) : color.new(#E65100, 0)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grp_bb = "── Bollinger Bands ──"
bb_on   = input.bool(true,  "Bollinger Bands Göster",  group=grp_bb)
bb_per  = input.int(20,     "BB Periyot",   minval=5,  group=grp_bb)
bb_mult = input.float(2.0,  "BB Çarpan",   minval=0.5, maxval=5.0, step=0.1, group=grp_bb)
bb_src  = input.source(close, "Kaynak",    group=grp_bb)

grp_kc = "── Keltner Channel ──"
kc_on   = input.bool(true,  "Keltner Channel Göster", group=grp_kc)
kc_per  = input.int(20,     "KC Periyot",   minval=5,  group=grp_kc)
kc_mult = input.float(1.5,  "KC ATR Çarpan", minval=0.5, maxval=5.0, step=0.1, group=grp_kc)

grp_sq = "── BB Squeeze ──"
sq_on   = input.bool(true, "Squeeze Tespiti Göster",  group=grp_sq)
sq_alert = input.bool(true, "Squeeze Alert Ver",      group=grp_sq)

grp_atr = "── ATR ──"
atr_on   = input.bool(true, "ATR Bantları Göster", group=grp_atr)
atr_per  = input.int(14,    "ATR Periyot", minval=2, group=grp_atr)
atr_mult = input.float(2.0, "ATR Bant Çarpan", minval=0.5, maxval=5.0, step=0.1, group=grp_atr)

// ══════════════════════════════════════════════════════════════
// BOLLINGER BANDS
// ══════════════════════════════════════════════════════════════
bb_basis = ta.sma(bb_src, bb_per)
bb_dev   = bb_mult * ta.stdev(bb_src, bb_per)
bb_upper = bb_basis + bb_dev
bb_lower = bb_basis - bb_dev
bb_width = (bb_upper - bb_lower) / bb_basis   // Normalize band width
bb_pct_b = (close - bb_lower) / (bb_upper - bb_lower)  // %B (0=alt band, 1=üst band)

// Band genişlik persentili (son 50 barda)
bb_width_pct = ta.percentrank(bb_width, 50)  // 0-100, düşük = dar = sıkışma

// ══════════════════════════════════════════════════════════════
// KELTNER CHANNEL
// ══════════════════════════════════════════════════════════════
kc_atr   = ta.atr(kc_per)
kc_basis = ta.ema(close, kc_per)
kc_upper = kc_basis + kc_mult * kc_atr
kc_lower = kc_basis - kc_mult * kc_atr

// ══════════════════════════════════════════════════════════════
// BB SQUEEZE — BB Keltner'in içindeyken sıkışma var
// Lazybear Squeeze Momentum mantığı
// ══════════════════════════════════════════════════════════════
squeeze_aktif   = bb_upper < kc_upper and bb_lower > kc_lower
squeeze_yok     = bb_upper > kc_upper and bb_lower < kc_lower

// Squeeze başlangıç ve bitiş
sq_basladi = squeeze_aktif and not squeeze_aktif[1]
sq_bitti   = not squeeze_aktif and squeeze_aktif[1]   // Patlama!

// Squeeze momentum (fiyatın bantların ortasına göre yönü)
sq_momentum_raw = close - ta.sma(math.max(math.max(high - low, math.abs(high - close[1])), math.abs(low - close[1])), kc_per) * 0.5
sq_momentum_ema = ta.linreg(sq_momentum_raw, kc_per, 0)

// ══════════════════════════════════════════════════════════════
// ATR BANTLARI
// ══════════════════════════════════════════════════════════════
atr_val   = ta.atr(atr_per)
atr_upper = close + atr_val * atr_mult
atr_lower = close - atr_val * atr_mult

// ══════════════════════════════════════════════════════════════
// VOLATİLİTE REJİMİ
// ══════════════════════════════════════════════════════════════
// Band width persentile göre rejim
vol_regime = bb_width_pct >= 70.0 ? "YÜKSEK VOL" :
             bb_width_pct <= 30.0 ? "DÜŞÜK VOL / SIKIŞ" :
             "NORMAL"

vol_regime_bull = sq_bitti and sq_momentum_ema > 0    // Patlama yukarı
vol_regime_bear = sq_bitti and sq_momentum_ema < 0    // Patlama aşağı

// Band breakout tespiti
bb_breakout_up   = ta.crossover(close,  bb_upper)
bb_breakout_down = ta.crossunder(close, bb_lower)

// ══════════════════════════════════════════════════════════════
// PLOT — Bollinger Bands
// ══════════════════════════════════════════════════════════════
bb_basis_col = is_dark ? color.new(#9E9E9E, 0) : color.new(#616161, 0)
bb_band_col  = squeeze_aktif ? color.new(C_WARN, 30) : color.new(C_ACCENT, 40)

bb_u_plot = plot(bb_on ? bb_upper : na, "BB Üst",  color=bb_band_col, linewidth=1)
bb_l_plot = plot(bb_on ? bb_lower : na, "BB Alt",  color=bb_band_col, linewidth=1)
plot(bb_on ? bb_basis : na, "BB Orta", color=bb_basis_col, linewidth=1, style=plot.style_circles)

// BB fill — sıkışma sırasında sarı, normal durumda şeffaf
bb_fill_col = squeeze_aktif ? color.new(C_WARN, 92) : color.new(C_ACCENT, 95)
fill(bb_u_plot, bb_l_plot, color=bb_on ? bb_fill_col : na, title="BB Fill")

// ══════════════════════════════════════════════════════════════
// PLOT — Keltner Channel
// ══════════════════════════════════════════════════════════════
kc_col = color.new(C_NEUT, 60)
kc_u_plot = plot(kc_on ? kc_upper : na, "KC Üst",  color=kc_col, linewidth=1, style=plot.style_line)
kc_l_plot = plot(kc_on ? kc_lower : na, "KC Alt",  color=kc_col, linewidth=1, style=plot.style_line)
plot(kc_on ? kc_basis : na, "KC Orta", color=color.new(C_NEUT, 80), linewidth=1)

// ══════════════════════════════════════════════════════════════
// PLOT — ATR Bantları (dinamik, her barda güncellenir)
// ══════════════════════════════════════════════════════════════
plot(atr_on ? atr_upper : na, "ATR Üst", color=color.new(C_BEAR, 70), linewidth=1, style=plot.style_stepline)
plot(atr_on ? atr_lower : na, "ATR Alt", color=color.new(C_BULL, 70), linewidth=1, style=plot.style_stepline)

// ══════════════════════════════════════════════════════════════
// SQUEEZE SİNYALLERİ
// ══════════════════════════════════════════════════════════════
// Squeeze devam ediyor: nokta grafiği
plotchar(sq_on and squeeze_aktif, "Squeeze Aktif", "◆", location.top,
         color=color.new(C_WARN, 40), size=size.tiny)

// Squeeze bitti = Patlama!
plotshape(sq_on and sq_bitti and vol_regime_bull, "Squeeze Patlama (↑)", shape.triangleup,
          location.belowbar, C_BULL, size=size.normal)
plotshape(sq_on and sq_bitti and vol_regime_bear, "Squeeze Patlama (↓)", shape.triangledown,
          location.abovebar, C_BEAR, size=size.normal)
plotshape(sq_on and sq_bitti and not vol_regime_bull and not vol_regime_bear, "Squeeze Patlama (?)", shape.circle,
          location.belowbar, C_WARN, size=size.small)

// BB Breakout işaretleri
plotshape(bb_breakout_up,   "BB Yukarı Kırılım",  shape.arrowup,   location.top,    C_BULL, size=size.small)
plotshape(bb_breakout_down, "BB Aşağı Kırılım",   shape.arrowdown, location.bottom, C_BEAR, size=size.small)

// ══════════════════════════════════════════════════════════════
// VOLATİLİTE ETİKETİ
// ══════════════════════════════════════════════════════════════
if barstate.islast
    pct_b_txt  = str.tostring(bb_pct_b * 100, "#.#") + "%"
    width_txt  = str.tostring(bb_width_pct, "#.#") + " persentil"
    atr_txt    = str.tostring(atr_val, "#.##")
    sq_txt     = squeeze_aktif ? "⚡SIKIŞ DEVAM" : "Serbest"

    vol_label_txt = vol_regime + "\n" +
                   "BB %B: " + pct_b_txt + "\n" +
                   "Band genişliği: " + width_txt + "\n" +
                   "ATR: " + atr_txt + "\n" +
                   "Squeeze: " + sq_txt

    vol_col = bb_width_pct >= 70 ? C_BEAR :
              bb_width_pct <= 30 ? C_WARN :
              C_NEUT

    label.new(bar_index + 2, bb_upper,
              vol_label_txt,
              color=color.new(vol_col, 80),
              textcolor=vol_col,
              style=label.style_label_left,
              size=size.small)

// ══════════════════════════════════════════════════════════════
// ALERTLER
// ══════════════════════════════════════════════════════════════
alertcondition(sq_basladi,       "Squeeze Başladı",       "⚡ SIKIŞ BAŞLADI | {{ticker}} — Patlama bekleniyor")
alertcondition(sq_bitti,         "Squeeze Bitti (Patlama)","🚀 PATLAMA! Squeeze Sona Erdi | {{ticker}} @ {{close}}")
alertcondition(vol_regime_bull,  "Yukarı Patlama",        "🟢 YUKARI PATLAMA (Squeeze) | {{ticker}} @ {{close}}")
alertcondition(vol_regime_bear,  "Aşağı Patlama",         "🔴 AŞAĞI PATLAMA (Squeeze) | {{ticker}} @ {{close}}")
alertcondition(bb_breakout_up,   "BB Yukarı Kırılım",     "🟢 BB Üst Band Kırılımı | {{ticker}} @ {{close}}")
alertcondition(bb_breakout_down, "BB Aşağı Kırılım",      "🔴 BB Alt Band Kırılımı | {{ticker}} @ {{close}}")

if barstate.isconfirmed
    if sq_bitti
        direction = vol_regime_bull ? "YUKARI" : vol_regime_bear ? "ASAGI" : "BELIRSIZ"
        alert('{"event":"SQUEEZE_PATLAMA","ticker":"' + syminfo.ticker + '","yon":"' + direction + '","price":' + str.tostring(close) + ',"atr":' + str.tostring(atr_val, "#.##") + '}', alert.freq_once_per_bar_close)
    if sq_basladi and sq_alert
        alert("⚡ Squeeze Başladı: " + syminfo.ticker + " — Patlama bekleniyor!", alert.freq_once_per_bar_close)
