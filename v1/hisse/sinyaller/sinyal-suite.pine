// @version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║        HİSSE SİNYAL PAKETİ — v6                              ║
// ║  Mum Formasyonları · Grafik Formasyonları · Konfluens        ║
// ║  Ağırlıklı Sinyal Skoru · Dinamik Alertler · Webhook         ║
// ║  BU DOSYA DİĞER 4 DOSYANIN ÇIKTISINI BİRLEŞTİRİR             ║
// ╚══════════════════════════════════════════════════════════════╝
indicator("Hisse Sinyal Paketi", overlay=true, max_bars_back=500, max_labels_count=200)

// ══════════════════════════════════════════════════════════════
// DARK MODE
// ══════════════════════════════════════════════════════════════
_bg_lum  = color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)
is_dark  = _bg_lum < 383

C_BULL   = is_dark ? color.new(#00C851, 0) : color.new(#006621, 0)
C_BEAR   = is_dark ? color.new(#FF4444, 0) : color.new(#CC0000, 0)
C_NEUT   = is_dark ? color.new(#9B9B9B, 0) : color.new(#444444, 0)
C_WARN   = is_dark ? color.new(#FFC107, 0) : color.new(#E65100, 0)
C_ACCENT = is_dark ? color.new(#2196F3, 0) : color.new(#1565C0, 0)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grp_mum = "── Mum Formasyonları ──"
mum_on   = input.bool(true, "Mum Formasyonları Göster", group=grp_mum)
mum_min  = input.float(0.001, "Min Gövde Oranı (body/range)", minval=0.0001, maxval=0.5, step=0.001, group=grp_mum)

grp_kf = "── Konfluens Skoru ──"
kf_min_al  = input.int(6, "AL için Min Skor (1-10)",  minval=1, maxval=10, group=grp_kf)
kf_min_sat = input.int(6, "SAT için Min Skor (1-10)", minval=1, maxval=10, group=grp_kf)
kf_goster  = input.bool(true, "Skor Etiketini Göster", group=grp_kf)

grp_mtf = "── Multi-Timeframe Doğrulama ──"
mtf_tf  = input.timeframe("D", "MTF Doğrulama Zaman Dilimi", group=grp_mtf)
mtf_on  = input.bool(true, "MTF Doğrulama Kullan", group=grp_mtf)

grp_grafik = "── Grafik Formasyonları ──"
grafik_on  = input.bool(true, "Grafik Formasyonları Göster", group=grp_grafik)
dt_lb      = input.int(20,    "Double Top/Bottom Lookback",  minval=10, maxval=100, group=grp_grafik)

grp_al = "── Alert Ayarları ──"
al_min_skor = input.int(7, "Alert için Min Skor",  minval=1, maxval=10, group=grp_al)
webhook_on  = input.bool(true, "Webhook (JSON) Alert",      group=grp_al)

// ══════════════════════════════════════════════════════════════
// TEMEL HESAPLAMALAR
// ══════════════════════════════════════════════════════════════
body     = math.abs(close - open)
range_   = high - low
wick_up  = high - math.max(close, open)
wick_dn  = math.min(close, open) - low
body_r   = range_ > 0 ? body / range_ : 0.0   // Gövde oranı (0-1)
is_bull_bar = close > open
is_bear_bar = close < open

// ══════════════════════════════════════════════════════════════
// MUM FORMASYONLARI
// ══════════════════════════════════════════════════════════════

// 1. Hammer / Hanging Man
hammer = is_bull_bar and wick_dn > body * 2.0 and wick_up < body * 0.5 and body > range_ * mum_min
hanging_man = is_bear_bar and wick_dn > body * 2.0 and wick_up < body * 0.5 and body > range_ * mum_min

// 2. Inverted Hammer / Shooting Star
inv_hammer   = is_bull_bar and wick_up > body * 2.0 and wick_dn < body * 0.5 and body > range_ * mum_min
shooting_star = is_bear_bar and wick_up > body * 2.0 and wick_dn < body * 0.5 and body > range_ * mum_min

// 3. Bullish Engulfing
bull_engulf = is_bear_bar[1] and is_bull_bar and
              close > open[1] and open < close[1] and
              body > body[1] * 0.8

// 4. Bearish Engulfing
bear_engulf = is_bull_bar[1] and is_bear_bar and
              close < open[1] and open > close[1] and
              body > body[1] * 0.8

// 5. Doji türleri
doji_body_max = range_ * 0.1   // Gövde range'in %10'undan küçükse doji
doji          = body < doji_body_max and range_ > 0
doji_dragon   = doji and wick_dn > range_ * 0.6 and wick_up < range_ * 0.2   // Dragonfly
doji_grave    = doji and wick_up > range_ * 0.6 and wick_dn < range_ * 0.2   // Gravestone

// 6. Pin Bar
pin_bar_bull = wick_dn > body * 2.5 and wick_up < wick_dn * 0.3
pin_bar_bear = wick_up > body * 2.5 and wick_dn < wick_up * 0.3

// 7. Morning Star (3 mum: ayı, doji/küçük, boğa)
morning_star = is_bear_bar[2] and body[2] > range_[2] * 0.4 and
               body[1] < range_[1] * 0.3 and   // Küçük gövde (doji benzeri)
               is_bull_bar and close > (open[2] + close[2]) / 2

// 8. Evening Star
evening_star = is_bull_bar[2] and body[2] > range_[2] * 0.4 and
               body[1] < range_[1] * 0.3 and
               is_bear_bar and close < (open[2] + close[2]) / 2

// 9. Three White Soldiers
three_soldiers = is_bull_bar and is_bull_bar[1] and is_bull_bar[2] and
                 close > close[1] and close[1] > close[2] and
                 open > open[1] and open[1] > open[2] and
                 body > range_ * 0.5 and body[1] > range_[1] * 0.5

// 10. Three Black Crows
three_crows = is_bear_bar and is_bear_bar[1] and is_bear_bar[2] and
              close < close[1] and close[1] < close[2] and
              open < open[1] and open[1] < open[2] and
              body > range_ * 0.5 and body[1] > range_[1] * 0.5

// 11. Inside Bar (konsolidasyon sinyali)
inside_bar = high < high[1] and low > low[1]

// 12. Outside Bar / Engulfing Range
outside_bar = high > high[1] and low < low[1]

// Bullish/Bearish formasyon özeti
bull_pattern = hammer or bull_engulf or doji_dragon or pin_bar_bull or morning_star or three_soldiers or inv_hammer
bear_pattern = hanging_man or bear_engulf or doji_grave or pin_bar_bear or evening_star or three_crows or shooting_star

// Formasyon adı (alert mesajı için)
pattern_name = bull_engulf    ? "Bullish Engulfing" :
               bear_engulf    ? "Bearish Engulfing" :
               hammer         ? "Hammer"            :
               hanging_man    ? "Hanging Man"       :
               morning_star   ? "Morning Star"      :
               evening_star   ? "Evening Star"      :
               three_soldiers ? "Three White Soldiers" :
               three_crows    ? "Three Black Crows"  :
               pin_bar_bull   ? "Bull Pin Bar"       :
               pin_bar_bear   ? "Bear Pin Bar"       :
               doji_dragon    ? "Dragonfly Doji"     :
               doji_grave     ? "Gravestone Doji"    :
               doji           ? "Doji"               :
               inside_bar     ? "Inside Bar"         : "—"

// ══════════════════════════════════════════════════════════════
// İNDİKATÖR VERİLERİ (Diğer dosyalarla uyum için yeniden hesap)
// ══════════════════════════════════════════════════════════════
ema50    = ta.ema(close, 50)
ema200   = ta.ema(close, 200)
[st_v, st_d] = ta.supertrend(3.0, 10)
rsi_v    = ta.rsi(close, 14)
[macd_l, macd_s, macd_h] = ta.macd(close, 12, 26, 9)
vol_avg  = ta.sma(volume, 20)
rel_vol  = vol_avg > 0 ? volume / vol_avg : 1.0

// BB Squeeze (Keltner içinde BB)
bb_up = ta.sma(close, 20) + 2.0 * ta.stdev(close, 20)
bb_lo = ta.sma(close, 20) - 2.0 * ta.stdev(close, 20)
kc_up = ta.ema(close, 20) + 1.5 * ta.atr(20)
kc_lo = ta.ema(close, 20) - 1.5 * ta.atr(20)
squeeze_aktif = bb_up < kc_up and bb_lo > kc_lo
sq_bitti = not squeeze_aktif and squeeze_aktif[1]

// MTF trend doğrulama
[mtf_e50, mtf_e200] = request.security(syminfo.tickerid, mtf_tf,
                       [ta.ema(close, 50), ta.ema(close, 200)],
                       lookahead=barmerge.lookahead_off)
mtf_yukari = mtf_on ? mtf_e50 > mtf_e200 : true

// Pivot yakınlığı (destek/direnç)
ph_lb = 10
ph = ta.pivothigh(high, ph_lb, ph_lb)
pl = ta.pivotlow(low, ph_lb, ph_lb)
var float last_res = na
var float last_sup = na
if not na(ph)
    last_res := ph
if not na(pl)
    last_sup := pl

atr_val = ta.atr(14)
near_sup = not na(last_sup) and math.abs(close - last_sup) < atr_val * 0.5
near_res = not na(last_res) and math.abs(close - last_res) < atr_val * 0.5

// ══════════════════════════════════════════════════════════════
// KONFLUENS SKORU (1-10 puan sistemi)
// ══════════════════════════════════════════════════════════════
// AL için puan (boğa koşulları)
al_skor  = 0
al_skor += close > ema200    ? 1 : 0   // 1. EMA 200 üstünde
al_skor += close > ema50     ? 1 : 0   // 2. EMA 50 üstünde
al_skor += st_d < 0          ? 1 : 0   // 3. SuperTrend yükseliş yönünde
al_skor += rsi_v > 45 and rsi_v < 70 ? 1 : 0  // 4. RSI sağlıklı momentum
al_skor += macd_h > 0        ? 1 : 0   // 5. MACD pozitif
al_skor += rel_vol >= 1.3    ? 1 : 0   // 6. Hacim desteği var
al_skor += sq_bitti          ? 1 : 0   // 7. Squeeze sonu patlama
al_skor += bull_pattern      ? 1 : 0   // 8. Boğa mum formasyonu
al_skor += mtf_yukari        ? 1 : 0   // 9. MTF trend uygun
al_skor += near_sup          ? 1 : 0   // 10. Destek seviyesine yakın

// SAT için puan (ayı koşulları)
sat_skor  = 0
sat_skor += close < ema200   ? 1 : 0
sat_skor += close < ema50    ? 1 : 0
sat_skor += st_d > 0         ? 1 : 0
sat_skor += rsi_v > 65       ? 1 : 0   // RSI aşırı alım bölgesinde
sat_skor += macd_h < 0       ? 1 : 0
sat_skor += rel_vol >= 1.3   ? 1 : 0
sat_skor += sq_bitti         ? 1 : 0
sat_skor += bear_pattern     ? 1 : 0
sat_skor += not mtf_yukari   ? 1 : 0
sat_skor += near_res         ? 1 : 0

// ══════════════════════════════════════════════════════════════
// ANA SİNYALLER
// ══════════════════════════════════════════════════════════════
al_sinyali  = al_skor  >= kf_min_al  and barstate.isconfirmed
sat_sinyali = sat_skor >= kf_min_sat and barstate.isconfirmed

// Güçlü sinyal: 8+ puan
al_guclu  = al_skor  >= 8 and barstate.isconfirmed
sat_guclu = sat_skor >= 8 and barstate.isconfirmed

// ══════════════════════════════════════════════════════════════
// GRAFIK FORMASYONLARI
// ══════════════════════════════════════════════════════════════
// Double Top: İki yakın yüksek, arada düşüş
var float dt_high1     = na
var int   dt_high1_bar = 0
var float db_low1      = na
var int   db_low1_bar  = 0

if not na(ph)
    if na(dt_high1) or ph > dt_high1 * 1.02
        dt_high1 := ph
        dt_high1_bar := bar_index
    else if ph > dt_high1 * 0.98 and ph < dt_high1 * 1.02 and bar_index - dt_high1_bar > 5
        // Double Top tespiti
        true

double_top    = not na(ph) and not na(dt_high1) and dt_high1 > 0 and math.abs(ph - dt_high1) / dt_high1 < 0.02 and (bar_index - dt_high1_bar) > 5

double_bottom = not na(pl) and not na(db_low1) and db_low1 > 0 and math.abs(pl - db_low1) / db_low1 < 0.02 and (bar_index - db_low1_bar) > 5

if not na(pl)
    if na(db_low1) or pl < db_low1 * 0.98
        db_low1 := pl
        db_low1_bar := bar_index

// Konsolidasyon kırılımı (Breakout)
consol_length = 20
highest_consol = ta.highest(high, consol_length)
lowest_consol  = ta.lowest(low,  consol_length)
consol_range   = highest_consol - lowest_consol
consol_tight   = consol_range / close < 0.05    // %5'ten dar konsolidasyon
breakout_up    = consol_tight and close > highest_consol[1] and rel_vol > 1.5
breakout_down  = consol_tight and close < lowest_consol[1]  and rel_vol > 1.5

// ══════════════════════════════════════════════════════════════
// PLOT — Mum Formasyonları
// ══════════════════════════════════════════════════════════════
// Boğa formasyonları (altta yeşil)
plotshape(mum_on and hammer,         "Hammer",     shape.labelup,    location.belowbar, C_BULL, text="H",  size=size.tiny)
plotshape(mum_on and bull_engulf,    "Bull Eng.",  shape.labelup,    location.belowbar, C_BULL, text="E",  size=size.tiny)
plotshape(mum_on and doji_dragon,    "Dragonfly",  shape.labelup,    location.belowbar, C_BULL, text="D",  size=size.tiny)
plotshape(mum_on and morning_star,   "Morn.Star",  shape.labelup,    location.belowbar, C_BULL, text="MS", size=size.tiny)
plotshape(mum_on and three_soldiers, "3 Soldiers", shape.labelup,    location.belowbar, C_BULL, text="3S", size=size.tiny)
plotshape(mum_on and pin_bar_bull,   "Bull Pin",   shape.labelup,    location.belowbar, color.new(C_BULL, 40), text="P", size=size.tiny)

// Ayı formasyonları (üstte kırmızı)
plotshape(mum_on and hanging_man,    "Hanging Man",shape.labeldown,  location.abovebar, C_BEAR, text="HM", size=size.tiny)
plotshape(mum_on and bear_engulf,    "Bear Eng.",  shape.labeldown,  location.abovebar, C_BEAR, text="E",  size=size.tiny)
plotshape(mum_on and doji_grave,     "Gravestone", shape.labeldown,  location.abovebar, C_BEAR, text="G",  size=size.tiny)
plotshape(mum_on and evening_star,   "Even.Star",  shape.labeldown,  location.abovebar, C_BEAR, text="ES", size=size.tiny)
plotshape(mum_on and three_crows,    "3 Crows",    shape.labeldown,  location.abovebar, C_BEAR, text="3C", size=size.tiny)
plotshape(mum_on and pin_bar_bear,   "Bear Pin",   shape.labeldown,  location.abovebar, color.new(C_BEAR, 40), text="P", size=size.tiny)

// ══════════════════════════════════════════════════════════════
// PLOT — Ana AL/SAT Sinyalleri
// ══════════════════════════════════════════════════════════════
// Normal sinyal
plotshape(al_sinyali  and not al_guclu,  "AL",       shape.triangleup,   location.belowbar, color.new(C_BULL, 20), size=size.small)
plotshape(sat_sinyali and not sat_guclu, "SAT",      shape.triangledown, location.abovebar, color.new(C_BEAR, 20), size=size.small)

// Güçlü sinyal (daha büyük)
plotshape(al_guclu,  "GÜÇLÜ AL",  shape.triangleup,   location.belowbar, C_BULL, size=size.normal)
plotshape(sat_guclu, "GÜÇLÜ SAT", shape.triangledown, location.abovebar, C_BEAR, size=size.normal)

// ══════════════════════════════════════════════════════════════
// PLOT — Grafik Formasyonları
// ══════════════════════════════════════════════════════════════
plotshape(grafik_on and double_top,    "Double Top",    shape.xcross,      location.abovebar, C_BEAR, text="DT", size=size.small)
plotshape(grafik_on and double_bottom, "Double Bottom", shape.xcross,      location.belowbar, C_BULL, text="DB", size=size.small)
plotshape(grafik_on and breakout_up,   "Breakout ↑",    shape.arrowup,     location.abovebar, C_BULL, size=size.small)
plotshape(grafik_on and breakout_down, "Breakout ↓",    shape.arrowdown,   location.belowbar, C_BEAR, size=size.small)

// ══════════════════════════════════════════════════════════════
// SKOR ETİKETİ
// ══════════════════════════════════════════════════════════════
if barstate.isconfirmed and kf_goster and (al_sinyali or sat_sinyali)
    skor_deger  = al_sinyali ? al_skor : sat_skor
    skor_yonu   = al_sinyali ? "AL" : "SAT"
    skor_rengi  = al_sinyali ? C_BULL : C_BEAR
    skor_pos    = al_sinyali ? low  - atr_val * 0.3 : high + atr_val * 0.3
    skor_style  = al_sinyali ? label.style_label_up : label.style_label_down

    label.new(bar_index, skor_pos,
              skor_yonu + " " + str.tostring(skor_deger) + "/10\n" + pattern_name,
              color=color.new(skor_rengi, 70),
              textcolor=skor_rengi,
              style=skor_style,
              size=size.small)

// ══════════════════════════════════════════════════════════════
// ALERTLER
// ══════════════════════════════════════════════════════════════
alertcondition(al_sinyali,  "AL Sinyali",       "🟢 AL | {{ticker}} @ {{close}}")
alertcondition(sat_sinyali, "SAT Sinyali",      "🔴 SAT | {{ticker}} @ {{close}}")
alertcondition(al_guclu,    "Güçlü AL",         "🚀 GÜÇLÜ AL (8+) | {{ticker}} @ {{close}}")
alertcondition(sat_guclu,   "Güçlü SAT",        "🔴 GÜÇLÜ SAT (8+) | {{ticker}} @ {{close}}")
alertcondition(bull_engulf, "Bull Engulfing",   "🕯️ Bullish Engulfing: {{ticker}} @ {{close}}")
alertcondition(bear_engulf, "Bear Engulfing",   "🕯️ Bearish Engulfing: {{ticker}} @ {{close}}")
alertcondition(morning_star,"Morning Star",     "🌅 Morning Star: {{ticker}} @ {{close}}")
alertcondition(evening_star,"Evening Star",     "🌆 Evening Star: {{ticker}} @ {{close}}")
alertcondition(breakout_up, "Breakout Yukarı",  "🚀 Breakout ↑: {{ticker}} @ {{close}}")
alertcondition(breakout_down,"Breakout Aşağı",  "📉 Breakout ↓: {{ticker}} @ {{close}}")

// Dinamik / Webhook alertleri
if barstate.isconfirmed
    if al_skor >= al_min_skor
        if webhook_on
            alert('{"event":"AL","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) +
                  ',"skor":' + str.tostring(al_skor) +
                  ',"formasyon":"' + pattern_name + '"' +
                  ',"tf":"' + timeframe.period + '"' +
                  ',"zaman":"' + str.tostring(timenow) + '"}',
                  alert.freq_once_per_bar_close)
        else
            alert("🟢 AL: " + syminfo.ticker + " | " + pattern_name + " | " + str.tostring(close, "#.##"), alert.freq_once_per_bar_close)

    if sat_skor >= al_min_skor
        if webhook_on
            alert('{"event":"SAT","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) +
                  ',"skor":' + str.tostring(sat_skor) +
                  ',"formasyon":"' + pattern_name + '"' +
                  ',"tf":"' + timeframe.period + '"' +
                  ',"zaman":"' + str.tostring(timenow) + '"}',
                  alert.freq_once_per_bar_close)
        else
            alert("🔴 SAT: " + syminfo.ticker + " | " + pattern_name + " | " + str.tostring(close, "#.##"), alert.freq_once_per_bar_close)