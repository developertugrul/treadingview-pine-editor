// @version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║         KRİPTO ANA PANELİ — v6                              ║
// ║  Multi-Timeframe Tablo · Kripto Özet Göstergesi             ║
// ╚══════════════════════════════════════════════════════════════╝
// NOT: Kripto piyasası 24/7 açıktır. Haftalık ve Günlük en güvenilir TF'dir.
indicator("Kripto Ana Panel", overlay=true, max_bars_back=500)

// ══════════════════════════════════════════════════════════════
// DARK MODE
// ══════════════════════════════════════════════════════════════
_bg_lum  = color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)
is_dark  = _bg_lum < 383

C_BULL   = is_dark ? color.new(#00E676, 0) : color.new(#00701A, 0)
C_BEAR   = is_dark ? color.new(#FF1744, 0) : color.new(#B71C1C, 0)
C_NEUT   = is_dark ? color.new(#9E9E9E, 0) : color.new(#424242, 0)
C_WARN   = is_dark ? color.new(#FFD740, 0) : color.new(#F57F17, 0)
C_ACCENT = is_dark ? color.new(#40C4FF, 0) : color.new(#0277BD, 0)
C_BG_CELL = is_dark ? color.new(#1A1A2E, 85) : color.new(#EEF0FA, 85)  // Kripto tema: koyu mavi
C_TEXT    = is_dark ? color.new(#E0E0E0, 0)  : color.new(#111111, 0)
C_BORDER  = is_dark ? color.new(#3A3A5A, 0)  : color.new(#BBBBCC, 0)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grp_panel = "── Panel ──"
panel_konum = input.string("Sağ Üst", "Konum",
              options=["Sağ Üst","Sağ Alt","Sol Üst","Sol Alt"], group=grp_panel)
panel_boyut = input.string("Normal", "Boyut",
              options=["Küçük","Normal","Büyük"], group=grp_panel)
mtf1 = input.timeframe("60",  "TF 1", group=grp_panel)
mtf2 = input.timeframe("240", "TF 2", group=grp_panel)
mtf3 = input.timeframe("D",   "TF 3", group=grp_panel)
mtf4 = input.timeframe("W",   "TF 4 (Kripto: Haftalık)", group=grp_panel)

// ══════════════════════════════════════════════════════════════
// MEVCUT TF HESAPLAMALARI
// ══════════════════════════════════════════════════════════════
ema50_cur  = ta.ema(close, 50)
ema200_cur = ta.ema(close, 200)
[st_cur, st_dir_cur] = ta.supertrend(3.5, 10)
rsi_cur    = ta.rsi(close, 14)
[_, _, macd_h_cur] = ta.macd(close, 12, 26, 9)
vol_avg_cur = ta.sma(volume, 20)
rel_vol_cur = vol_avg_cur > 0 ? volume / vol_avg_cur : 1.0
sq_cur      = ta.sma(close,20) + 2.5*ta.stdev(close,20) < ta.ema(close,20) + 2.0*ta.atr(20) and
              ta.sma(close,20) - 2.5*ta.stdev(close,20) > ta.ema(close,20) - 2.0*ta.atr(20)
atr_cur     = ta.atr(14)

// ══════════════════════════════════════════════════════════════
// MTF VERİLERİ
// ══════════════════════════════════════════════════════════════
f_skor(tf) =>
    _e50  = request.security(syminfo.tickerid, tf, ta.ema(close,50),  lookahead=barmerge.lookahead_off)
    _e200 = request.security(syminfo.tickerid, tf, ta.ema(close,200), lookahead=barmerge.lookahead_off)
    _rsi  = request.security(syminfo.tickerid, tf, ta.rsi(close,14),  lookahead=barmerge.lookahead_off)
    [_,_,_hist] = request.security(syminfo.tickerid, tf, ta.macd(close,12,26,9), lookahead=barmerge.lookahead_off)
    [_st,_stdir] = request.security(syminfo.tickerid, tf, ta.supertrend(3.5,10), lookahead=barmerge.lookahead_off)
    _cl   = request.security(syminfo.tickerid, tf, close, lookahead=barmerge.lookahead_off)
    _sc   = (_cl > _e50 ? 2 : -2) + (_cl > _e200 ? 2 : -2) + (_stdir < 0 ? 2 : -2) + (_rsi > 50 ? 1 : -1) + (_hist > 0 ? 1 : -1)
    [_rsi, _hist > 0, _stdir < 0, _cl > _e200, math.max(0.0, math.min(10.0, (_sc + 8.0) / 1.6))]

[rsi1, macd1p, st1up, tr1, sk1] = f_skor(mtf1)
[rsi2, macd2p, st2up, tr2, sk2] = f_skor(mtf2)
[rsi3, macd3p, st3up, tr3, sk3] = f_skor(mtf3)
[rsi4, macd4p, st4up, tr4, sk4] = f_skor(mtf4)

// ══════════════════════════════════════════════════════════════
// YARDIMCILAR
// ══════════════════════════════════════════════════════════════
ok_sym(b)    => b ? "↑" : "↓"
ok_col(b)    => b ? C_BULL : C_BEAR
rsi_c(r)     => r >= 75 ? C_BEAR : r <= 25 ? C_BULL : r >= 55 ? color.new(C_BULL,40) : r <= 45 ? color.new(C_BEAR,40) : C_NEUT
skor_c(s)    => s >= 7 ? C_BULL : s <= 3 ? C_BEAR : C_WARN

// ══════════════════════════════════════════════════════════════
// TABLO
// ══════════════════════════════════════════════════════════════
tbl_pos = panel_konum == "Sağ Üst"  ? position.top_right    :
          panel_konum == "Sağ Alt"  ? position.bottom_right  :
          panel_konum == "Sol Üst"  ? position.top_left      : position.bottom_left

txt_s = panel_boyut == "Küçük" ? size.tiny : panel_boyut == "Büyük" ? size.normal : size.small

var table tbl = table.new(tbl_pos, 7, 9, border_width=1, border_color=C_BORDER, frame_color=C_BORDER, frame_width=1)

if barstate.islast
    // Başlık
    hdr_col = color.new(C_ACCENT, 65)
    table.cell(tbl, 0, 0, "₿ " + syminfo.ticker,   text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)
    table.cell(tbl, 1, 0, "Anlık",   text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)
    table.cell(tbl, 2, 0, mtf1,      text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)
    table.cell(tbl, 3, 0, mtf2,      text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)
    table.cell(tbl, 4, 0, mtf3,      text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)
    table.cell(tbl, 5, 0, mtf4,      text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)
    table.cell(tbl, 6, 0, "Ref.",    text_color=C_TEXT, bgcolor=hdr_col, text_size=txt_s)

    // Fiyat
    degisim = (close - close[1]) / close[1] * 100
    fp_col  = degisim >= 0 ? C_BULL : C_BEAR
    table.cell(tbl, 0, 1, "Fiyat",   text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 1, str.tostring(close,"#.##"), text_color=fp_col, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 1, str.tostring(degisim,"+#.##") + "%", text_color=fp_col, bgcolor=C_BG_CELL, text_size=txt_s)
    for c = 3 to 5
        table.cell(tbl, c, 1, "", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 1, "vs önceki bar", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // SuperTrend
    st_c = st_dir_cur < 0 ? C_BULL : C_BEAR
    st_t = st_dir_cur < 0 ? "YUKARI" : "AŞAĞI"
    table.cell(tbl, 0, 2, "Trend",           text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 2, st_t,              text_color=st_c,   bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 2, ok_sym(st1up),     text_color=ok_col(st1up), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 3, 2, ok_sym(st2up),     text_color=ok_col(st2up), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 4, 2, ok_sym(st3up),     text_color=ok_col(st3up), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 5, 2, ok_sym(st4up),     text_color=ok_col(st4up), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 2, "SuperTrend(3.5)", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // EMA 200
    ema_c = close > ema200_cur ? C_BULL : C_BEAR
    table.cell(tbl, 0, 3, "EMA 200",         text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 3, close > ema200_cur ? "Üstünde" : "Altında", text_color=ema_c, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 3, ok_sym(tr1),       text_color=ok_col(tr1), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 3, 3, ok_sym(tr2),       text_color=ok_col(tr2), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 4, 3, ok_sym(tr3),       text_color=ok_col(tr3), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 5, 3, ok_sym(tr4),       text_color=ok_col(tr4), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 3, "Uzun Vade",       text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // RSI (Kripto OB/OS: 75/25)
    table.cell(tbl, 0, 4, "RSI (75/25)",     text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 4, str.tostring(rsi_cur,"#.#"), text_color=rsi_c(rsi_cur), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 4, str.tostring(rsi1,"#.#"), text_color=rsi_c(rsi1), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 3, 4, str.tostring(rsi2,"#.#"), text_color=rsi_c(rsi2), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 4, 4, str.tostring(rsi3,"#.#"), text_color=rsi_c(rsi3), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 5, 4, str.tostring(rsi4,"#.#"), text_color=rsi_c(rsi4), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 4, "RSI(14)",         text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // MACD
    macd_t = macd_h_cur > 0 ? (macd_h_cur > macd_h_cur[1] ? "↑POZ" : "↓POZ") : (macd_h_cur < macd_h_cur[1] ? "↓NEG" : "↑NEG")
    macd_c = macd_h_cur > 0 ? C_BULL : C_BEAR
    table.cell(tbl, 0, 5, "MACD",            text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 5, macd_t,            text_color=macd_c, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 5, ok_sym(macd1p),    text_color=ok_col(macd1p), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 3, 5, ok_sym(macd2p),    text_color=ok_col(macd2p), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 4, 5, ok_sym(macd3p),    text_color=ok_col(macd3p), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 5, 5, ok_sym(macd4p),    text_color=ok_col(macd4p), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 5, "MACD(12,26,9)",   text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // Volatilite/Squeeze
    vol_t = sq_cur ? "SIKIŞ⚡" : rel_vol_cur > 2.5 ? "YÜKSEK HAC" : "Normal"
    vol_c = sq_cur ? C_WARN : rel_vol_cur > 2.5 ? C_WARN : C_NEUT
    table.cell(tbl, 0, 6, "Volatilite",      text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 6, vol_t,             text_color=vol_c,  bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 6, str.tostring(rel_vol_cur,"#.##") + "x", text_color=rel_vol_cur > 2.5 ? C_WARN : C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)
    for c = 3 to 5
        table.cell(tbl, c, 6, "", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 6, "BB(2.5)+KC(2.0)", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // Skor
    def_sc = (close > ema50_cur ? 2:-2) + (close > ema200_cur ? 2:-2) + (st_dir_cur < 0 ? 2:-2) + (rsi_cur > 50 ? 1:-1) + (macd_h_cur > 0 ? 1:-1)
    sc_cur = math.max(0.0, math.min(10.0, (def_sc + 8.0) / 1.6))
    table.cell(tbl, 0, 7, "Skor /10",        text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 7, str.tostring(sc_cur,"#.#"), text_color=skor_c(sc_cur), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 7, str.tostring(sk1,"#.#"), text_color=skor_c(sk1), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 3, 7, str.tostring(sk2,"#.#"), text_color=skor_c(sk2), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 4, 7, str.tostring(sk3,"#.#"), text_color=skor_c(sk3), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 5, 7, str.tostring(sk4,"#.#"), text_color=skor_c(sk4), bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 7, "Konfluens",       text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)

    // ATR bilgisi
    table.cell(tbl, 0, 8, "ATR / Risk",      text_color=C_TEXT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 1, 8, str.tostring(atr_cur,"#.##"), text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 2, 8, str.tostring(atr_cur/close*100,"#.##") + "%", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)
    for c = 3 to 5
        table.cell(tbl, c, 8, "", text_color=C_NEUT, bgcolor=C_BG_CELL, text_size=txt_s)
    table.cell(tbl, 6, 8, "SL = 1.5-2x ATR", text_color=C_WARN, bgcolor=C_BG_CELL, text_size=txt_s)
