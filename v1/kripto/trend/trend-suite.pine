// @version=6
// ╔══════════════════════════════════════════════════════════════╗
// ║         KRİPTO TREND PAKETİ — v6                             ║
// ║  EMA · SuperTrend · Fibonacci · S/R · 24/7 Piyasa           ║
// ║  Birlikte Çalışır: momentum-suite · volatilite-suite         ║
// ╚══════════════════════════════════════════════════════════════╝
// NOT: Kripto için ATR çarpanı ve periyotlar daha agresif ayarlıdır.
// BTC/ETH gibi büyük kaplar için günlük/4 saatlik kullan.
// Altcoin'lerde SuperTrend çarpanını 3.5-4.0 yapabilirsin.
indicator("Kripto Trend Paketi", overlay=true, max_bars_back=500, max_lines_count=100, max_labels_count=50)

// ══════════════════════════════════════════════════════════════
// DARK MODE
// ══════════════════════════════════════════════════════════════
_bg_lum  = color.r(chart.bg_color) + color.g(chart.bg_color) + color.b(chart.bg_color)
is_dark  = _bg_lum < 383

C_BULL   = is_dark ? color.new(#00E676, 0) : color.new(#00701A, 0)  // Kripto için daha parlak yeşil
C_BEAR   = is_dark ? color.new(#FF1744, 0) : color.new(#B71C1C, 0)
C_NEUT   = is_dark ? color.new(#9E9E9E, 0) : color.new(#424242, 0)
C_ACCENT = is_dark ? color.new(#40C4FF, 0) : color.new(#0277BD, 0)  // Kripto teması: mavi
C_WARN   = is_dark ? color.new(#FFD740, 0) : color.new(#F57F17, 0)  // Altın sarısı (BTC rengi)

// ══════════════════════════════════════════════════════════════
// INPUTS
// ══════════════════════════════════════════════════════════════
grp_ema = "── Hareketli Ortalamalar ──"
ema21_on  = input.bool(true,  "EMA 21 Göster",  group=grp_ema)
ema50_on  = input.bool(true,  "EMA 50 Göster",  group=grp_ema)
ema100_on = input.bool(true,  "EMA 100 Göster", group=grp_ema)
ema200_on = input.bool(true,  "EMA 200 Göster", group=grp_ema)
bar_renk  = input.bool(true,  "Bar Renklendirme", group=grp_ema)

grp_st = "── SuperTrend ──"
st_on    = input.bool(true,   "SuperTrend Göster",   group=grp_st)
st_per   = input.int(10,      "Periyot",  minval=3,  group=grp_st)
st_mult  = input.float(3.5,   "Çarpan (Kripto için 3.5-4.0 önerilir)", minval=0.5, maxval=10, step=0.1, group=grp_st)

grp_fib = "── Fibonacci Seviyeleri ──"
fib_on  = input.bool(true, "Fibonacci Göster", group=grp_fib)
fib_lb  = input.int(50,    "Fib Lookback (bar)", minval=20, maxval=200, group=grp_fib)

grp_sr = "── Destek / Direnç ──"
sr_on  = input.bool(true, "S/R Seviyeleri Göster", group=grp_sr)
sr_lb  = input.int(14,    "Pivot Lookback", minval=5, maxval=50, group=grp_sr)

grp_mtf = "── Multi-Timeframe ──"
mtf_on = input.bool(true, "MTF Trend Göster", group=grp_mtf)
mtf_tf = input.timeframe("D", "Konfirmasyon TF", group=grp_mtf)

grp_btc = "── BTC Korelasyonu ──"
btc_on = input.bool(false, "BTC Trend Karşılaştır (overlay)", group=grp_btc)

// ══════════════════════════════════════════════════════════════
// EMA HESAPLAMALARI
// ══════════════════════════════════════════════════════════════
ema21  = ta.ema(close, 21)
ema50  = ta.ema(close, 50)
ema100 = ta.ema(close, 100)
ema200 = ta.ema(close, 200)

ema_yukari = ema21 > ema50 and ema50 > ema100
ema_asagi  = ema21 < ema50 and ema50 < ema100

golden_cross = ta.crossover(ema50,  ema200)
death_cross  = ta.crossunder(ema50, ema200)

// ══════════════════════════════════════════════════════════════
// SUPERTREND
// ══════════════════════════════════════════════════════════════
[st_val, st_dir] = ta.supertrend(st_mult, st_per)
st_yukari = st_dir < 0
st_asagi  = st_dir > 0
st_alim   = ta.crossunder(st_dir, 0)
st_satim  = ta.crossover(st_dir,  0)

// ══════════════════════════════════════════════════════════════
// FİBONACCİ SEVİYELERİ (Lookback içinde swing high-low)
// ══════════════════════════════════════════════════════════════
fib_high = ta.highest(high, fib_lb)
fib_low  = ta.lowest(low,   fib_lb)
fib_diff = fib_high - fib_low

fib_236 = fib_high - fib_diff * 0.236
fib_382 = fib_high - fib_diff * 0.382
fib_500 = fib_high - fib_diff * 0.500
fib_618 = fib_high - fib_diff * 0.618
fib_786 = fib_high - fib_diff * 0.786

// ══════════════════════════════════════════════════════════════
// MTF TREND
// ══════════════════════════════════════════════════════════════
[mtf_e50, mtf_e200, mtf_cl] = request.security(syminfo.tickerid, mtf_tf,
    [ta.ema(close,50), ta.ema(close,200), close],
    lookahead=barmerge.lookahead_off)

mtf_yukari = mtf_e50 > mtf_e200
genel_yukari = st_yukari and mtf_yukari
genel_asagi  = st_asagi  and not mtf_yukari

// ══════════════════════════════════════════════════════════════
// DİNAMİK S/R
// ══════════════════════════════════════════════════════════════
ph = ta.pivothigh(high, sr_lb, sr_lb)
pl = ta.pivotlow(low,   sr_lb, sr_lb)

var float res1 = na, var float res2 = na, var float res3 = na
var float sup1 = na, var float sup2 = na, var float sup3 = na

if not na(ph)
    res3 := res2; res2 := res1; res1 := ph
if not na(pl)
    sup3 := sup2; sup2 := sup1; sup1 := pl

// ══════════════════════════════════════════════════════════════
// PLOT — EMAlar
// ══════════════════════════════════════════════════════════════
c_e21  = is_dark ? color.new(#FFD740, 0) : color.new(#F57F17, 0)   // Altın (BTC rengi)
c_e50  = is_dark ? color.new(#40C4FF, 0) : color.new(#0277BD, 0)   // Mavi
c_e100 = is_dark ? color.new(#EA80FC, 0) : color.new(#7B1FA2, 0)   // Mor
c_e200 = is_dark ? color.new(#FF6E40, 0) : color.new(#BF360C, 0)   // Derin turuncu

p_e21  = plot(ema21_on  ? ema21  : na, "EMA 21",  color=c_e21,  linewidth=1)
p_e50  = plot(ema50_on  ? ema50  : na, "EMA 50",  color=c_e50,  linewidth=2)
         plot(ema100_on ? ema100 : na, "EMA 100", color=c_e100, linewidth=2)
         plot(ema200_on ? ema200 : na, "EMA 200", color=c_e200, linewidth=3)

// EMA 21/50 fill
ema_fill_col = ema21 > ema50 ? color.new(C_BULL, 90) : color.new(C_BEAR, 90)
fill(p_e21, p_e50, color=ema_fill_col, title="EMA 21/50 Fill")

// ══════════════════════════════════════════════════════════════
// PLOT — SuperTrend
// ══════════════════════════════════════════════════════════════
st_col = st_yukari ? C_BULL : C_BEAR
plot(st_on ? st_val : na, "SuperTrend", color=st_col, linewidth=2)
plotshape(st_on and st_alim,  "ST Alım",  shape.triangleup,   location.belowbar, C_BULL, size=size.small)
plotshape(st_on and st_satim, "ST Satım", shape.triangledown, location.abovebar, C_BEAR, size=size.small)

// ══════════════════════════════════════════════════════════════
// PLOT — Fibonacci
// ══════════════════════════════════════════════════════════════
fib_alpha = 50
plot(fib_on ? fib_236 : na, "Fib 23.6%", color=color.new(C_WARN,  fib_alpha), linewidth=1, style=plot.style_circles)
plot(fib_on ? fib_382 : na, "Fib 38.2%", color=color.new(C_WARN,  fib_alpha - 10), linewidth=1, style=plot.style_circles)
plot(fib_on ? fib_500 : na, "Fib 50.0%", color=color.new(C_ACCENT,fib_alpha - 10), linewidth=2, style=plot.style_circles)
plot(fib_on ? fib_618 : na, "Fib 61.8%", color=color.new(C_WARN,  fib_alpha - 10), linewidth=1, style=plot.style_circles)
plot(fib_on ? fib_786 : na, "Fib 78.6%", color=color.new(C_WARN,  fib_alpha), linewidth=1, style=plot.style_circles)

// ══════════════════════════════════════════════════════════════
// PLOT — S/R
// ══════════════════════════════════════════════════════════════
plot(sr_on ? res1 : na, "Direnç 1", color=color.new(C_BEAR, 20), linewidth=2, style=plot.style_circles)
plot(sr_on ? res2 : na, "Direnç 2", color=color.new(C_BEAR, 55), linewidth=1, style=plot.style_circles)
plot(sr_on ? res3 : na, "Direnç 3", color=color.new(C_BEAR, 75), linewidth=1, style=plot.style_circles)
plot(sr_on ? sup1 : na, "Destek 1", color=color.new(C_BULL, 20), linewidth=2, style=plot.style_circles)
plot(sr_on ? sup2 : na, "Destek 2", color=color.new(C_BULL, 55), linewidth=1, style=plot.style_circles)
plot(sr_on ? sup3 : na, "Destek 3", color=color.new(C_BULL, 75), linewidth=1, style=plot.style_circles)

// Golden/Death Cross
plotshape(golden_cross, "Golden Cross", shape.star,   location.belowbar, C_WARN, size=size.normal)
plotshape(death_cross,  "Death Cross",  shape.xcross, location.abovebar, C_BEAR, size=size.normal)

// ══════════════════════════════════════════════════════════════
// BAR RENK
// ══════════════════════════════════════════════════════════════
bar_col = genel_yukari ? color.new(C_BULL, 65) :
          genel_asagi  ? color.new(C_BEAR, 65) :
          color.new(C_NEUT, 80)
barcolor(bar_renk ? bar_col : na)

// ══════════════════════════════════════════════════════════════
// TREND ETİKETİ
// ══════════════════════════════════════════════════════════════
if barstate.islast
    fib_yakin = math.abs(close - fib_618) / close < 0.01 ? " [FIB 61.8%!]" :
                math.abs(close - fib_500) / close < 0.01 ? " [FIB 50%]" :
                math.abs(close - fib_382) / close < 0.01 ? " [FIB 38.2%]" : ""

    trend_txt = genel_yukari ? "▲ YUKARI TREND" :
                genel_asagi  ? "▼ AŞAĞI TREND"  :
                st_yukari    ? "↗ ST Yükseliş"   :
                "~ Kararsız"
    trend_col = genel_yukari ? C_BULL : genel_asagi ? C_BEAR : C_NEUT

    label.new(bar_index + 2, high,
              trend_txt + fib_yakin + "\nMTF " + mtf_tf + ": " + (mtf_yukari ? "↑" : "↓"),
              color=color.new(trend_col, 80),
              textcolor=trend_col,
              style=label.style_label_left,
              size=size.normal)

// ══════════════════════════════════════════════════════════════
// ALERTLER
// ══════════════════════════════════════════════════════════════
alertcondition(golden_cross,             "Golden Cross",        "🟡 GOLDEN CROSS | {{ticker}} @ {{close}}")
alertcondition(death_cross,              "Death Cross",         "🔴 DEATH CROSS  | {{ticker}} @ {{close}}")
alertcondition(st_alim,                  "SuperTrend Alım",     "🟢 ST ALIM | {{ticker}} @ {{close}}")
alertcondition(st_satim,                 "SuperTrend Satım",    "🔴 ST SATIM | {{ticker}} @ {{close}}")
alertcondition(genel_yukari and st_alim, "Güçlü Kripto Alım",  "🚀 GÜÇLÜ ALIM — Kripto | {{ticker}} @ {{close}}")

if barstate.isconfirmed
    if st_alim
        alert('{"event":"KRIPTO_ST_ALIM","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"tf":"' + timeframe.period + '"}', alert.freq_once_per_bar_close)
    if st_satim
        alert('{"event":"KRIPTO_ST_SATIM","ticker":"' + syminfo.ticker + '","price":' + str.tostring(close) + ',"tf":"' + timeframe.period + '"}', alert.freq_once_per_bar_close)
